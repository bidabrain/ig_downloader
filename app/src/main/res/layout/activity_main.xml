<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- URL input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/ig_pink">

        <EditText
            android:id="@+id/urlInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/url_hint"
            android:inputType="textUri"
            android:imeOptions="actionGo"
            android:singleLine="true"
            android:background="@android:color/white"
            android:padding="10dp"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:textColorHint="#888888"
            android:saveEnabled="false" />

        <Button
            android:id="@+id/loadBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_load"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/ig_dark" />
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:max="100"
        android:visibility="gone"
        android:progressTint="@color/ig_pink"
        android:progressBackgroundTint="#DDDDDD"
        android:minHeight="18dp" />

    <!-- Status text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:textSize="12sp"
        android:text="Paste an Instagram URL above and tap Load" />

    <!-- WebView: hidden by default, shown only when Instagram login is required -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- Download button fixed at bottom -->
    <Button
        android:id="@+id/downloadBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:text="@string/btn_download"
        android:backgroundTint="@color/ig_pink"
        android:textColor="@color/white"
        android:textSize="16sp" />

</LinearLayout>
